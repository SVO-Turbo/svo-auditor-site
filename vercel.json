{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/audit", "dest": "api/audit.py" },
    { "src": "/api/capture", "dest": "api/capture.py" },
    { "src": "/", "dest": "index.html" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
